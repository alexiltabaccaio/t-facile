{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "{firebase-applet-config.json,metadata.json}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
