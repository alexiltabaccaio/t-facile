# Environment
NODE_ENV=development

# The Gemini API key is now read directly from Firestore at /secrets/gemini
# GEMINI_API_KEY is no longer required here.

# For Vercel or other environments where uploading service-account.json is not possible,
# you must paste the entire JSON content of the file into this environment variable.
# FIREBASE_SERVICE_ACCOUNT_KEY={"type": "service_account", "project_id": "..."}
