# Ambiente
NODE_ENV=development

# La chiave API di Gemini ora viene letta direttamente da Firestore in /secrets/gemini
# GEMINI_API_KEY non è più necessaria qui.

# Per Vercel o altri ambienti dove non è possibile caricare il file service-account.json
# è necessario inserire l'intero contenuto JSON del file in questa variabile d'ambiente.
# FIREBASE_SERVICE_ACCOUNT_KEY={"type": "service_account", "project_id": "..."}
